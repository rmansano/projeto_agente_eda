# ============================================================
# Variáveis de ambiente do projeto
# Copie este arquivo para .env e preencha com suas chaves.
# O arquivo .env NÃO deve ser commitado no Git!
# ============================================================

# Chave da API da Anthropic (Claude)
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# (Opcional) Chave da OpenAI
# OPENAI_API_KEY=sk-your-key-here

# (Opcional) Chave do Google
# GOOGLE_API_KEY=your-key-here
DEEPSEEK_API_KEY=your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Modelo a ser usado (deve estar entre os "mini/flash/haiku")
LLM_MODEL=deepseek-v4-flash
LLM_PROVIDER=deepseek
